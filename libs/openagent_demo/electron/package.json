{
  "name": "openagent",
  "version": "0.0.1",
  "description": "OpenAgent Desktop App",
  "main": "main.js",
  "scripts": {
    "dev": "ELECTRON_DEV=1 electron .",
    "build:mac": "electron-builder --mac --arm64",
    "build:mac-x64": "electron-builder --mac --x64",
    "build:mac-universal": "electron-builder --mac --universal",
    "build:mac-all": "electron-builder --mac --arm64 --x64",
    "build:win": "electron-builder --win --x64",
    "build:win-arm64": "electron-builder --win --arm64",
    "build:all": "electron-builder --mac --win"
  },
  "dependencies": {
    "tree-kill": "^1.2.2"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.openagent.app",
    "productName": "OpenAgent",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../frontend/dist",
        "to": "frontend"
      },
      {
        "from": "backend_dist/",
        "to": "backend"
      },
      {
        "from": "lima_dist/",
        "to": "lima"
      }
    ],
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        }
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.developer-tools",
      "identity": null,
      "signIgnore": []
    },
    "afterPack": "./scripts/afterPack.js",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
